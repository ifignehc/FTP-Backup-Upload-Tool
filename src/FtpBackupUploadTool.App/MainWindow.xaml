<Window x:Class="FtpBackupUploadTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FtpBackupUploadTool.App.Controls"
        xmlns:converters="clr-namespace:FtpBackupUploadTool.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="Assets/AppIcon.ico"
        Title="FTP BU Tool"
        Height="780"
        MinHeight="680"
        Width="1360"
        MinWidth="1120"
        Background="#F4F6F8"
        KeyDown="OnWindowKeyDown">
    <Window.Resources>
        <converters:LogForegroundConverter x:Key="LogForegroundConverter" />
        <SolidColorBrush x:Key="FilePaneFrameBrush" Color="#CFD7E3" />
        <SolidColorBrush x:Key="ActivePaneBorderBrush" Color="#2563EB" />
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="FilePaneFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource FilePaneFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="FunctionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,7" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="155" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding BackupCommand}" Content="备份" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding UploadCommand}" Content="上传" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding CheckCommand}" Content="检查" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding OpenSettingsCommand}" Content="设置" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Text="工序" />
                <ComboBox Width="190"
                          ItemsSource="{Binding Processes}"
                          SelectedItem="{Binding SelectedProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock VerticalAlignment="Center" Margin="18,0,0,0" Foreground="#475467" Text="{Binding RootSummary}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="路径清单">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,6"
                            Padding="12,5"
                            Command="{Binding ConsolidatePathListCommand}"
                            Content="整合" />

                    <TextBox Grid.Row="1"
                             Padding="10"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Text="{Binding PathListText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"
                               Foreground="#475467"
                               Text="{Binding PathListCountDisplay}" />
                </Grid>
            </GroupBox>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="ProductionPaneFrame"
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource FilePaneFrameStyle}">
                    <GroupBox Header="{Binding ProductionPane.Title}">
                        <controls:FilePaneControl x:Name="ProductionFilePane"
                                                  DataContext="{Binding ProductionPane}"
                                                  PaneActivated="OnFilePaneActivated"
                                                  PathRefreshRequested="OnFilePanePathRefreshRequested"
                                                  CopyRequested="OnFilePaneCopyRequested" />
                    </GroupBox>
                </Border>

                <Border x:Name="DraftPaneFrame"
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource FilePaneFrameStyle}">
                    <GroupBox Header="{Binding DraftPane.Title}">
                        <controls:FilePaneControl x:Name="DraftFilePane"
                                                  DataContext="{Binding DraftPane}"
                                                  PaneActivated="OnFilePaneActivated"
                                                  PathRefreshRequested="OnFilePanePathRefreshRequested"
                                                  CopyRequested="OnFilePaneCopyRequested"
                                                  PasteRequested="OnFilePanePasteRequested"
                                                  DeleteRequested="OnFilePaneDeleteRequested"
                                                  FilesDropped="OnFilePaneFilesDropped" />
                    </GroupBox>
                </Border>

                <Border x:Name="LocalPaneFrame"
                        Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource FilePaneFrameStyle}">
                    <GroupBox Header="{Binding LocalPane.Title}">
                        <controls:FilePaneControl x:Name="LocalFilePane"
                                                  DataContext="{Binding LocalPane}"
                                                  PaneActivated="OnFilePaneActivated"
                                                  PathRefreshRequested="OnFilePanePathRefreshRequested"
                                                  CopyRequested="OnFilePaneCopyRequested"
                                                  PasteRequested="OnFilePanePasteRequested"
                                                  DeleteRequested="OnFilePaneDeleteRequested"
                                                  FilesDropped="OnFilePaneFilesDropped" />
                    </GroupBox>
                </Border>

                <Border x:Name="BackupPaneFrame"
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource FilePaneFrameStyle}">
                    <GroupBox Header="{Binding BackupPane.Title}">
                        <controls:FilePaneControl x:Name="BackupFilePane"
                                                  DataContext="{Binding BackupPane}"
                                                  PaneActivated="OnFilePaneActivated"
                                                  PathRefreshRequested="OnFilePanePathRefreshRequested"
                                                  CopyRequested="OnFilePaneCopyRequested"
                                                  PasteRequested="OnFilePanePasteRequested"
                                                  DeleteRequested="OnFilePaneDeleteRequested"
                                                  FilesDropped="OnFilePaneFilesDropped" />
                    </GroupBox>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Padding="8"
                Background="#E7EEF6"
                BorderBrush="#C6D3E1"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource FunctionButtonStyle}" Content="F8 删除" Click="OnFunctionDeleteClicked" />
                <Button Style="{StaticResource FunctionButtonStyle}" Content="F9 刷新" Click="OnFunctionRefreshClicked" />
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="3" Margin="0,10,0,0" Header="日志窗口">
            <ListBox Padding="8"
                     Background="#101828"
                     FontFamily="Consolas"
                     HorizontalContentAlignment="Stretch"
                     ItemsSource="{Binding Logs}"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Foreground="{Binding Converter={StaticResource LogForegroundConverter}}"
                                   Text="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</Window>
