<Window x:Class="FtpBackupUploadTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FtpBackupUploadTool.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FTP备份上传工具"
        Height="720"
        MinHeight="620"
        Width="1180"
        MinWidth="980"
        Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding BackupCommand}" Content="备份" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding UploadCommand}" Content="上传" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding CheckCommand}" Content="检查" />
                <Button MinWidth="88" Margin="8,0,0,0" Padding="14,8" Command="{Binding OpenSettingsCommand}" Content="设置" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Text="工序" />
                <ComboBox Width="180"
                          ItemsSource="{Binding Processes}"
                          SelectedItem="{Binding SelectedProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock VerticalAlignment="Center" Margin="18,0,0,0" Foreground="#475467" Text="{Binding RootSummary}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="路径清单">
                <TextBox Padding="10"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         Text="{Binding PathListText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="{Binding ProductionPane.Title}">
                <controls:FilePaneControl DataContext="{Binding ProductionPane}" />
            </GroupBox>

            <GroupBox Grid.Column="4" Header="{Binding DraftPane.Title}">
                <controls:FilePaneControl DataContext="{Binding DraftPane}" />
            </GroupBox>

            <GroupBox Grid.Column="6" Header="{Binding LocalPane.Title}">
                <controls:FilePaneControl DataContext="{Binding LocalPane}" />
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Margin="0,12,0,0" Header="日志窗口">
            <ListBox Padding="8"
                     FontFamily="Consolas"
                     HorizontalContentAlignment="Stretch"
                     ItemsSource="{Binding Logs}"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </GroupBox>
    </Grid>
</Window>
