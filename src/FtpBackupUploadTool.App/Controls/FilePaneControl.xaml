<UserControl x:Class="FtpBackupUploadTool.App.Controls.FilePaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Drop="OnDrop"
             GotKeyboardFocus="OnPaneActivated"
             PreviewMouseDown="OnPaneActivated">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,5" LastChildFill="True">
            <Button DockPanel.Dock="Left"
                    Width="30"
                    Margin="0,0,5,0"
                    Content="↑"
                    Click="OnUpClicked"
                    ToolTip="上一级" />
            <Button DockPanel.Dock="Right"
                    MinWidth="48"
                    Margin="5,0,0,0"
                    Padding="8,4"
                    Content="刷新"
                    Click="OnRefreshClicked" />
            <Button DockPanel.Dock="Right"
                    MinWidth="48"
                    Margin="5,0,0,0"
                    Padding="8,4"
                    Content="进入"
                    Click="OnGoClicked" />
            <TextBox x:Name="pathTextBox"
                     Padding="8,5"
                     FontFamily="Consolas"
                     Text="{Binding CurrentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnPathTextBoxKeyDown" />
        </DockPanel>

        <TextBox Grid.Row="1"
                 Margin="0,0,0,5"
                 Padding="8,4"
                 Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="快速过滤当前窗口文件" />

        <ListView x:Name="fileListView"
                  Grid.Row="2"
                  ItemsSource="{Binding FilteredFiles}"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  GridViewColumnHeader.Click="OnColumnHeaderClicked"
                  PreviewMouseLeftButtonDown="OnListViewPreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="OnListViewPreviewMouseLeftButtonUp"
                  PreviewMouseMove="OnListViewPreviewMouseMove"
                  MouseDoubleClick="OnListViewMouseDoubleClick"
                  ContextMenuOpening="OnContextMenuOpening">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="copyMenuItem" Header="复制" Click="OnCopyClicked" />
                    <MenuItem x:Name="pasteMenuItem" Header="粘贴" Click="OnPasteClicked" />
                    <MenuItem x:Name="deleteMenuItem" Header="删除" Click="OnDeleteClicked" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="190" DisplayMemberBinding="{Binding DisplayName}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="名称/路径" Tag="Name" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="84" DisplayMemberBinding="{Binding SizeDisplay}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="大小" Tag="Size" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding LastModifiedDisplay}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="修改时间" Tag="LastModified" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="3"
                   Margin="0,4,0,0"
                   HorizontalAlignment="Right"
                   Foreground="#475467"
                   Text="{Binding ItemCountSummary}" />
    </Grid>
</UserControl>
