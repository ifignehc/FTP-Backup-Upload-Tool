<UserControl x:Class="FtpBackupUploadTool.App.Controls.FilePaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Drop="OnDrop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="True">
            <Button DockPanel.Dock="Left"
                    Width="32"
                    Margin="0,0,6,0"
                    Content="↑"
                    Click="OnUpClicked"
                    ToolTip="上一级" />
            <Button DockPanel.Dock="Right"
                    MinWidth="56"
                    Margin="6,0,0,0"
                    Padding="10,5"
                    Content="进入"
                    Click="OnGoClicked" />
            <TextBox x:Name="pathTextBox"
                     Padding="8,6"
                     Text="{Binding CurrentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnPathTextBoxKeyDown" />
        </DockPanel>

        <ListView x:Name="fileListView"
                  Grid.Row="1"
                  ItemsSource="{Binding Files}"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  PreviewMouseLeftButtonDown="OnListViewPreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="OnListViewPreviewMouseLeftButtonUp"
                  PreviewMouseMove="OnListViewPreviewMouseMove"
                  MouseDoubleClick="OnListViewMouseDoubleClick"
                  ContextMenuOpening="OnContextMenuOpening">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="copyMenuItem" Header="复制" Click="OnCopyClicked" />
                    <MenuItem x:Name="pasteMenuItem" Header="粘贴" Click="OnPasteClicked" />
                    <MenuItem x:Name="deleteMenuItem" Header="删除" Click="OnDeleteClicked" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="160" Header="名称/路径" DisplayMemberBinding="{Binding DisplayName}" />
                    <GridViewColumn Width="80" Header="大小" DisplayMemberBinding="{Binding SizeDisplay}" />
                    <GridViewColumn Width="150" Header="修改时间" DisplayMemberBinding="{Binding LastModifiedDisplay}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
