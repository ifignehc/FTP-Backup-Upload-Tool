<UserControl x:Class="FtpBackupUploadTool.App.Controls.FilePaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Drop="OnDrop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Margin="0,0,0,6"
                 Padding="8,6"
                 IsReadOnly="True"
                 Text="{Binding CurrentPath}" />

        <ListView x:Name="fileListView"
                  Grid.Row="1"
                  ItemsSource="{Binding Files}"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  PreviewMouseMove="OnListViewPreviewMouseMove"
                  ContextMenuOpening="OnContextMenuOpening">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="copyMenuItem" Header="复制" Click="OnCopyClicked" />
                    <MenuItem x:Name="pasteMenuItem" Header="粘贴" Click="OnPasteClicked" />
                    <MenuItem x:Name="deleteMenuItem" Header="删除" Click="OnDeleteClicked" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="160" Header="名称/路径" DisplayMemberBinding="{Binding Path.Value}" />
                    <GridViewColumn Width="80" Header="大小" DisplayMemberBinding="{Binding Size}" />
                    <GridViewColumn Width="150" Header="修改时间" DisplayMemberBinding="{Binding LastModified}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
