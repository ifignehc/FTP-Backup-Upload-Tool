<Window x:Class="FtpBackupUploadTool.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="../Assets/AppIcon.ico"
        Title="设置"
        Height="720"
        Width="1080"
        MinWidth="900"
        MinHeight="600"
        Background="#F4F6F8">
    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#D0D5DD"
                BorderThickness="0,1,0,0"
                Background="#FFFFFF"
                Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Width="80"
                        Margin="4,0"
                        Padding="12,7"
                        IsCancel="True" />
                <Button Content="保存设置"
                        Width="100"
                        Margin="4,0"
                        Padding="12,7"
                        Click="OnSaveClick" />
            </StackPanel>
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="工序">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="新增" Width="62" Margin="0,0,6,0" Click="OnAddProcessClick" />
                        <Button Content="复制" Width="62" Margin="0,0,6,0" Click="OnCopyProcessClick" />
                        <Button Content="删除" Width="62" Click="OnDeleteProcessClick" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Processes}"
                             SelectedItem="{Binding SelectedProcess}" />
                </DockPanel>
            </GroupBox>

            <ScrollViewer Grid.Column="1"
                          Margin="12,0,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="工序基础信息" Margin="0,0,0,10">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="工序名称" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="生产服务器 FTP" Margin="0,0,0,10">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="IP / 域名" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding ProductionHost, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" />
                            <TextBox Grid.Column="3" Text="{Binding ProductionPort, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="4" Text="账号" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding ProductionAccount, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="6" Text="密码" VerticalAlignment="Center" />
                            <DockPanel Grid.Column="7">
                                <CheckBox x:Name="RememberProductionPasswordCheckBox"
                                          Content="记住"
                                          DockPanel.Dock="Right"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"
                                          IsChecked="{Binding RememberProductionPassword}"
                                          Click="OnRememberPasswordChanged" />
                                <PasswordBox x:Name="ProductionPasswordBox" Padding="8,6" ToolTip="{Binding ProductionPasswordHint}" />
                            </DockPanel>
                            <CheckBox Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="7"
                                      Content="被动模式"
                                      IsChecked="{Binding ProductionUsePassive}"
                                      Margin="0,10,0,0"
                                      ToolTip="默认开启；如果公司 FTP 可以登录但文件列表刷新失败，可关闭后保存并重试。" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="起案服务器 FTP" Margin="0,0,0,10">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="IP / 域名" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding DraftHost, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" />
                            <TextBox Grid.Column="3" Text="{Binding DraftPort, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="4" Text="账号" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding DraftAccount, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="6" Text="密码" VerticalAlignment="Center" />
                            <DockPanel Grid.Column="7">
                                <CheckBox x:Name="RememberDraftPasswordCheckBox"
                                          Content="记住"
                                          DockPanel.Dock="Right"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"
                                          IsChecked="{Binding RememberDraftPassword}"
                                          Click="OnRememberPasswordChanged" />
                                <PasswordBox x:Name="DraftPasswordBox" Padding="8,6" ToolTip="{Binding DraftPasswordHint}" />
                            </DockPanel>
                            <CheckBox Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="7"
                                      Content="被动模式"
                                      IsChecked="{Binding DraftUsePassive}"
                                      Margin="0,10,0,0"
                                      ToolTip="默认开启；如果公司 FTP 可以登录但文件列表刷新失败，可关闭后保存并重试。" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="根目录、备份与检查日志" Margin="0,0,0,10">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="服务器根目录" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Column="1" Text="{Binding ServerRoot}" Padding="8,6" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="1" Text="备份保存目录" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BackupDirectory}" Padding="8,6" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="2" Text="备份文件夹命名模板" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BackupTemplate}" Padding="8,6" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="3" Text="检查日志保存目录" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CheckLogDirectory}" Padding="8,6" Margin="0,0,0,8" />
                            <TextBlock Grid.Row="4" Text="检查日志命名模板" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CheckLogTemplate}" Padding="8,6" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="备份日志内容">
                        <ItemsControl ItemsSource="{Binding LogFields}" Margin="12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked}"
                                              Margin="4,5"
                                              Padding="2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
